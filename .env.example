# LLM Provider (groq / mistral / claude)
LLM_PROVIDER=groq
GROQ_API_KEY=
MISTRAL_API_KEY=
ANTHROPIC_API_KEY=

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb
ELEVENLABS_MODEL=eleven_multilingual_v2

# Server
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# CORS — set to production frontend URL on Render
FRONTEND_URL=http://localhost:4200

# Sentry (optional — leave empty to disable)
SENTRY_DSN=

# LangSmith (optional — leave empty to skip tracing and eval dashboard)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=voxpopuli-evals

# Eval config
EVAL_API_URL=http://localhost:3000
EVAL_JUDGE_PROVIDER=mistral

# Multi-Agent Pipeline (M8)
# Set to 'true' to enable the multi-agent pipeline by default.
# When false, the legacy single ReAct agent is used.
USE_MULTI_AGENT=false
